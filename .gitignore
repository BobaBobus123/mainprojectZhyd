# === Тимчасові файли Qt Creator та CMake ===
CMakeLists.txt.user
.qtc/
*.pro.user
*.pyc

# === Папки збірки (Build directories) ===
# Ігноруємо всі папки, що починаються на build
build*/
bin/
obj/

# === Тимчасові файли компілятора ===
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.exe
*.pdb
*.exp

# === Автогенерований код Qt (moc, uic, rcc) ===
# Ці файли створюються автоматично під час збірки
moc_*.cpp
ui_*.h
qrc_*.cpp
*_autogen/

# === База даних (локальна) ===
